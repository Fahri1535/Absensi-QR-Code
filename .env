APP_NAME="Presensi QR"
APP_ENV=local
APP_KEY=base64:XdU+jnq4mtyIIQlh6HIR6l1h6zHL1J3cxnI66TY0xbw=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# DATABASE (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# SESSION, CACHE, QUEUE (PAKAI FILE BIAR SIMPLE)
SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

# MAIL (dummy)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="admin@presensi.test"
MAIL_FROM_NAME="${APP_NAME}"

# Ubah ke WhatsApp/email HR Anda — dipakai tautan "Hubungi Admin" di login
ADMIN_CONTACT_URL="mailto:admin@presensi.test"

VITE_APP_NAME="${APP_NAME}"